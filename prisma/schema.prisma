// AutoService Super App - Comprehensive Prisma Schema
// Supports 4 Service Models: Direct Booking, E-Commerce, Indrive/Broadcast, Ekfik Lifecycle
// ================================================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ================================================================================================
// USER & PROFILE MANAGEMENT
// ================================================================================================

// أدوار المستخدمين المعتمدة للعرض: عميل، مسؤول، موظف، مورد، فني (SUPPLIER قديم — يُعرض "مورد")
enum UserRole {
  CUSTOMER // عميل
  ADMIN // مسؤول
  EMPLOYEE // موظف (صلاحيات من لوحة الأدمن)
  VENDOR // مورد
  TECHNICIAN // فني
  SUPPLIER // قديم — للتوافق مع بيانات موجودة، يُعرض كـ "مورد"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum Language {
  EN // English
  AR // Arabic
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  phone             String?    @unique
  passwordHash      String
  role              UserRole
  status            UserStatus @default(PENDING_VERIFICATION)
  emailVerified     Boolean    @default(false)
  phoneVerified     Boolean    @default(false)
  preferredLanguage Language   @default(AR) // Default to Arabic
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  profile   Profile?
  vehicles  UserVehicle[] // Customer's vehicles
  addresses Address[]

  // Bookings
  bookingsAsCustomer   Booking[] @relation("CustomerBookings")
  bookingsAsTechnician Booking[] @relation("TechnicianBookings")

  // Broadcasts & Offers
  jobBroadcasts JobBroadcast[]
  jobOffers     JobOffer[]

  // Mobile Workshop Requests (customer)
  mobileWorkshopRequests MobileWorkshopRequest[]
  chatMessages           ChatMessage[]

  // Inspections & Supply
  inspectionReports InspectionReport[]
  supplyRequests    SupplyRequest[]    @relation("TechnicianSupplyRequests")
  supplierRequests  SupplyRequest[]    @relation("SupplierSupplyRequests")

  // Financials
  invoices          Invoice[]
  wallet            Wallet?
  transactions      Transaction[]
  payments          Payment[]
  pointTransactions PointTransaction[]

  // Notifications & Ratings
  notifications   Notification[]
  activityLogs    ActivityLog[]
  ratingsGiven    Rating[]          @relation("RaterRatings")
  ratingsReceived Rating[]          @relation("RateeRatings")
  vendorReviews   VendorReview[]    @relation("VendorReviews")
  deviceTokens    UserDeviceToken[]

  // Location Tracking
  technicianLocations TechnicianLocation[] @relation("TechnicianLocations")

  // Vendor Relations
  vendorProfile     VendorProfile?
  vendorApplication Vendor?            @relation("VendorApplication")
  autoParts         AutoPart[]         @relation("VendorParts")
  marketplaceOrders MarketplaceOrder[]
  cart              Cart?
  autoPartFavorites AutoPartFavorite[]

  // Workshop Reviews
  workshopReviews WorkshopReview[]

  // Feedback Module
  feedbacks         Feedback[]         @relation("UserFeedbacks")
  handledFeedbacks  Feedback[]         @relation("HandledFeedbacks")
  feedbackReplies   FeedbackReply[]
  feedbackAuditLogs FeedbackAuditLog[]

  // Technical Support
  supportRequestsAsCustomer TechnicalSupportRequest[] @relation("CustomerSupportRequests")
  supportRequestsAsTech     TechnicalSupportRequest[] @relation("TechnicianSupportRequests")
  supportRequestsAssigned   TechnicalSupportRequest[] @relation("AssignedSupportRequests")

  // Admin Transactions
  performedTransactions      Transaction[]      @relation("TransactionPerformer")
  performedPointTransactions PointTransaction[] @relation("PointTransactionPerformer")
  vendor                     Vendor?            @relation(fields: [vendorId], references: [id])
  vendorId                   String?

  // موظفو المنصة (EMPLOYEE) — صلاحيات من لوحة الأدمن فقط (ربط بفيندور اختياري)
  employeePermissions EmployeePermission[]
  vendorEmployment    VendorEmployee? // ربط اختياري بفيندور إن لزم

  // خدمة أكفيك — رحلة موجّهة (تأمين / ورشة / سحب)
  akfeekJourneys AkfeekJourney[]

  // Packages
  userPackages UserPackage[]

  // Certified workshop vendor offers (prepaid bundles & percent promos)
  workshopOfferPurchases UserWorkshopOfferPurchase[]

  @@index([email])
  @@index([phone])
  @@index([role, status])
}

// ================================================================================================
// PUSH NOTIFICATIONS (FCM device tokens)
// ================================================================================================

enum DevicePlatform {
  ANDROID
  IOS
  WEB
  OTHER
}

model UserDeviceToken {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token    String         @unique
  platform DevicePlatform @default(OTHER)
  deviceId String?

  isActive   Boolean   @default(true)
  lastSeenAt DateTime  @default(now())
  lastSentAt DateTime?
  lastError  String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([lastSeenAt])
}

model Profile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  avatar    String?
  bio       String? @db.Text
  bioAr     String? @db.Text // Arabic bio

  // Technician-specific
  licenseNumber   String?
  yearsExperience Int?
  specializations Json? // Array of service types
  serviceRadius   Float? // km radius for emergency services
  isAvailable     Boolean @default(true)

  // Supplier-specific
  businessName      String?
  businessNameAr    String? // Arabic business name
  businessLicense   String?
  warehouseLocation String?

  // Location (for real-time tracking)
  currentLat         Float?
  currentLng         Float?
  lastLocationUpdate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Address {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label      String // "Home", "Work", etc.
  labelAr    String? // Arabic label
  street     String
  streetAr   String? // Arabic street name
  city       String
  cityAr     String? // Arabic city name
  state      String?
  stateAr    String? // Arabic state name
  postalCode String?
  country    String  @default("SA")

  latitude  Float
  longitude Float

  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings               Booking[]
  jobBroadcasts          JobBroadcast[]
  mobileWorkshopRequests MobileWorkshopRequest[]

  @@index([userId])
}

// ================================================================================================
// VEHICLE MANAGEMENT
// ================================================================================================

enum VehicleType {
  SEDAN // سيدان - Standard sedan cars
  HATCHBACK // هاتشباك - Hatchback cars
  COUPE // كوبيه - Coupe cars
  SMALL_SUV // دفع رباعي صغير - Compact SUV
  LARGE_SEDAN // سيدان كبيرة - Full-size sedan
  SUV // دفع رباعي - Sport Utility Vehicle
  CROSSOVER // كروس أوفر - Crossover SUV
  TRUCK // شاحنة/بيك أب - Pickup truck
  VAN // فان - Van
  BUS // باص - Bus
}

// New: Separate brand and model tables for better data management
model VehicleBrand {
  id       String  @id @default(uuid())
  name     String  @unique // Toyota, BMW, Mercedes-Benz
  nameAr   String? // تويوتا, بي ام دبليو
  logo     String? // Brand logo URL
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  models    VehicleModel[]
  autoParts AutoPart[]     @relation("AutoPartBrand")

  @@index([name])
}

model VehicleModel {
  id      String       @id @default(uuid())
  brandId String
  brand   VehicleBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  name     String // Camry, X5, C-Class
  nameAr   String? // كامري
  year     Int
  type     VehicleType
  imageUrl String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userVehicles        UserVehicle[]
  compatibleAutoParts AutoPartCompatibility[]
  autoParts           AutoPart[] // القطع المرتبطة بهذا الموديل

  @@unique([brandId, name, year])
  @@index([brandId])
  @@index([name])
}

model UserVehicle {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Vehicle Model Reference
  vehicleModelId String
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id])

  // Basic Information
  ownerName String? // الأسم - Owner name

  // License Plate Information (Saudi Format)
  plateLettersAr String? // الأحرف العربية - Arabic letters (e.g., "ع س س")
  plateLettersEn String? // الأحرف الإنجليزية - English letters (e.g., "SEJ")
  plateDigits    String // الأرقام - Digits (e.g., "7415")
  plateRegion    String? // رمز المنطقة - Region code (e.g., "K", "أ")
  // plateNumber محسوب من الأجزاء أعلاه ولا يُخزّن في DB

  color          String? // اللون
  vin            String? @unique // رقم الهيكل - Chassis number
  currentMileage Int? // عداد الكيلومترات

  // Engine Information
  fuelType           String? // نوع الوقود - Petrol/Diesel/Electric/Hybrid
  engineCapacity     String? // سعة المحرك - e.g., "2.0L", "3.5L"
  engineSerialNumber String? // الرقم التسلسلي للمحرك

  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings               Booking[]
  mobileWorkshopRequests MobileWorkshopRequest[]
  akfeekJourneys         AkfeekJourney[]
  maintenanceRecords     VehicleMaintenanceRecord[]
  documents              UserVehicleDocument[]

  @@index([userId])
  @@index([vehicleModelId])
}

model VehicleMaintenanceRecord {
  id                  String          @id @default(uuid())
  vehicleId           String
  vehicle             UserVehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date                DateTime
  type                MaintenanceType
  workshopName        String?
  cost                Decimal?        @db.Decimal(10, 2)
  nextMaintenanceDate DateTime?
  notes               String?         @db.Text
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([vehicleId])
  @@index([date])
  @@index([nextMaintenanceDate])
}

enum MaintenanceType {
  OIL_CHANGE
  ENGINE_REPAIR
  BRAKES
  TIRES
  AC
  ELECTRICAL
  SUSPENSION
  BODY_REPAIR
  PAINTING
  DIAGNOSIS
  BATTERY
  TRANSMISSION
  DETAILING
  GLASS
  GENERAL_MAINTENANCE
  OTHER
}

// ================================================================================================
// SERVICE CATALOG DOMAIN
// ================================================================================================

enum ServiceType {
  FIXED // Direct Booking: Car Wash, Polishing
  CATALOG // E-Commerce: Oil Change, Filter Replacement
  EMERGENCY // Indrive/Broadcast: Roadside, Mobile Workshop
  INSPECTION // Ekfik Lifecycle: Valet & Inspection
  MOBILE_CAR_SERVICE // خدمة الزرَش / الصيانة المتنقلة - Parent with sub-services
}

enum ServiceCategory {
  CLEANING
  MAINTENANCE
  REPAIR
  EMERGENCY
  INSPECTION
  COMPREHENSIVE_CARE
  CUSTOMIZATION
  CERTIFIED_WORKSHOP
}

enum DeliveryMethod {
  FLATBED // سطحة - Akfeek sends a flatbed
  SELF_DELIVERY // تسليم للمركز - Customer delivers vehicle
}

model Service {
  id            String  @id @default(uuid())
  name          String
  nameAr        String?
  description   String? @db.Text
  descriptionAr String? @db.Text

  type     ServiceType
  category ServiceCategory

  imageUrl String?
  icon     String?

  isActive          Boolean @default(true)
  requiresVehicle   Boolean @default(true)
  estimatedDuration Int? // minutes

  // Mobile Car Service: parent service contains sub-services
  parentServiceId  String?
  parentService    Service?  @relation("MobileCarSubServices", fields: [parentServiceId], references: [id], onDelete: SetNull)
  subServices      Service[] @relation("MobileCarSubServices")
  customAttributes Json? // Per sub-service custom attributes (not shared)

  // Comprehensive Care: service owned by a vendor (فيندور العناية الشاملة)
  vendorId String?
  vendor   VendorProfile? @relation("VendorComprehensiveCareServices", fields: [vendorId], references: [id], onDelete: SetNull)

  // مواعيد العمل للحجز (العناية الشاملة): يوم الأسبوع + من - إلى. يمنع حجز عميلين في نفس الوقت
  workingHours        Json? // [{ "dayOfWeek": 0, "start": "09:00", "end": "17:00" }, ...] 0=Sun, 6=Sat
  slotDurationMinutes Int? // مدة كل موعد بالدقائق (افتراضي 60)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  pricing          ServicePricing[]
  bookingServices  BookingService[]
  addOns           ServiceAddOn[]    @relation("ServiceAddOns")
  parentAddOns     ServiceAddOn[]    @relation("ParentService")
  autoPartServices AutoPartService[]

  // Package relations
  packageServices PackageService[]

  @@index([type, isActive])
  @@index([category])
  @@index([parentServiceId])
  @@index([vendorId])
}

model ServicePricing {
  id        String  @id @default(uuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  vehicleType     String // اسم حر من الفيندور (مثلاً سيدان، دفع رباعي، عربية صغيرة)
  basePrice       Decimal  @db.Decimal(10, 2)
  discountedPrice Decimal? @db.Decimal(10, 2)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, vehicleType])
  @@index([serviceId])
}

model ServiceAddOn {
  id        String  @id @default(uuid())
  serviceId String
  service   Service @relation("ParentService", fields: [serviceId], references: [id], onDelete: Cascade)

  addOnId String
  addOn   Service @relation("ServiceAddOns", fields: [addOnId], references: [id])

  additionalPrice Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  @@unique([serviceId, addOnId])
  @@index([serviceId])
}

// ================================================================================================
// AUTO PARTS MARKETPLACE - VENDOR MANAGEMENT & PARTS CATALOG
// ================================================================================================

enum VendorStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  REJECTED
}

enum VendorType {
  AUTO_PARTS // فيندور قطع الغيار / المنتجات
  COMPREHENSIVE_CARE // فيندور العناية الشاملة
  CERTIFIED_WORKSHOP // فيندور الورش المعتمدة
  CAR_WASH // فيندور خدمة الغسيل
  MOBILE_WORKSHOP // مقدم خدمة الورش المتنقلة
  TOWING_SERVICE // مقدم خدمة السحب والونش
  ADHMN_AKFEEK // أكفيك - أكymen
}

model VendorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  vendorType VendorType @default(AUTO_PARTS) // نوع الفيندور: قطع غيار أو عناية شاملة

  businessName   String
  businessNameAr String?
  description    String? @db.Text
  descriptionAr  String? @db.Text

  // الشروط والأحكام
  termsAndConditions   String? @db.Text // English terms
  termsAndConditionsAr String? @db.Text // Arabic terms

  // Registration Documents
  commercialLicense String?
  taxNumber         String?

  // Contact Information
  contactPhone String
  contactEmail String

  // Address
  address String?
  city    String?
  country String  @default("SA")

  // Business Details
  logo   String?
  banner String?

  // Commission — نسبة عمولة التطبيق الخاصة بهذا الفيندور (تتجاوز الإعداد العام إذا كانت محددة)
  commissionPercent Float? // مثال: 8.5 تعني 8.5% — null يعني استخدام الإعداد العام

  // Verification & Status
  status     VendorStatus @default(PENDING_APPROVAL)
  isVerified Boolean      @default(false)
  verifiedAt DateTime?

  // Ratings & Stats
  averageRating Float? @default(0)
  totalReviews  Int    @default(0)
  totalSales    Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  parts                     AutoPart[]             @relation("VendorOwnedParts")
  orderItems                MarketplaceOrderItem[]
  autoPartVendors           AutoPartVendor[] // Vendors supplying parts (pricing & availability)
  bookingAutoParts          BookingAutoPart[] // Bookings where this vendor supplied parts
  comprehensiveCareServices Service[]              @relation("VendorComprehensiveCareServices") // خدمات العناية الشاملة
  workshop                  CertifiedWorkshop? // فيندور الورش المعتمدة: ورشة واحدة مرتبطة به
  winch                     Winch? // فيندور الونش: سيارة سحب واحدة مرتبطة به
  mobileWorkshop            MobileWorkshop? // فيندور الورش المتنقلة: ورشة متنقلة واحدة مرتبطة به

  reviews         VendorReview[]
  documents       VendorDocument[]
  coupons         Coupon[]
  serviceOffers   VendorServiceOffer[]
  vendorEmployees VendorEmployee[] // موظفو هذا الفيندور

  @@index([userId])
  @@index([status])
  @@index([isVerified])
}

// صلاحيات الموظف — يُعيّنها الأدمن من الداشبورد (الموظف يشوف صلاحياته من لوحة الأدمن)
model EmployeePermission {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionKey String // مثلاً: bookings, vendors, invoices
  createdAt     DateTime @default(now())

  @@unique([userId, permissionKey])
  @@index([userId])
}

// ربط اختياري للموظف بفيندور (إن وُجد — الموظف أساساً صلاحياته من الأدمن)
model VendorEmployee {
  id        String        @id @default(uuid())
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([vendorId])
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

enum ServiceOfferTargetType {
  SERVICE
  CERTIFIED_WORKSHOP_SERVICE
  MOBILE_WORKSHOP_SERVICE
}

model VendorServiceOffer {
  id String @id @default(uuid())

  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  targetType ServiceOfferTargetType
  targetId   String

  /// 1–100 percent
  discountPercent Int

  title   String?
  titleAr String?

  validFrom  DateTime @default(now())
  validUntil DateTime
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId, isActive])
  @@index([targetType, targetId])
  @@index([validUntil])
}

model Coupon {
  id             String             @id @default(uuid())
  vendorId       String
  vendor         VendorProfile      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  code           String // كود الكوبون (فريد ضمن نفس الفيندور)
  discountType   CouponDiscountType @default(PERCENT)
  discountValue  Decimal            @db.Decimal(10, 2)
  minOrderAmount Decimal?           @db.Decimal(10, 2)
  validFrom      DateTime           @default(now())
  validUntil     DateTime
  maxUses        Int? // null = غير محدود
  usedCount      Int                @default(0)
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([vendorId, code])
  @@index([vendorId])
  @@index([isActive])
  @@index([validFrom, validUntil])
}

model VendorReview {
  id       String        @id @default(uuid())
  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  userId   String
  user     User          @relation("VendorReviews", fields: [userId], references: [id], onDelete: Cascade)

  rating  Int     @db.SmallInt // 1-5
  comment String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, userId]) // مستخدم واحد = تقييم واحد لكل فيندور
  @@index([vendorId])
  @@index([userId])
}

model VendorDocument {
  id       String        @id @default(uuid())
  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  docType  String // COMMERCIAL_LICENSE | TAX_CERTIFICATE | INSURANCE | VEHICLE_REGISTRATION | DRIVER_LICENSE | IDENTITY_CARD | CERTIFICATION | OTHER
  name     String // اسم المستند المعروض
  fileUrl  String // المسار النسبي للملف
  fileSize Int? // الحجم بالبايت
  mimeType String? // image/jpeg | application/pdf ...

  uploadedAt DateTime @default(now())

  @@index([vendorId])
  @@index([docType])
}

// نوع الفئة الجذرية لقطع الغيار: سيارات أو دراجات نارية
enum AutoPartRootType {
  CAR // قطع غيار سيارات
  MOTORCYCLE // قطع غيار دراجات نارية
}

model AutoPartCategory {
  id            String             @id @default(uuid())
  name          String             @unique
  nameAr        String?
  description   String?            @db.Text
  descriptionAr String?            @db.Text
  icon          String?
  imageUrl      String?
  parentId      String?
  parent        AutoPartCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      AutoPartCategory[] @relation("CategoryHierarchy")
  // للفئات الجذرية فقط: CAR = قطع غيار سيارات، MOTORCYCLE = قطع غيار دراجات نارية
  rootType      AutoPartRootType?
  isActive      Boolean            @default(true)
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  parts AutoPart[]

  @@index([parentId])
  @@index([isActive])
  @@index([rootType])
}

model AutoPart {
  id            String  @id @default(uuid())
  sku           String  @unique
  name          String
  nameAr        String?
  description   String? @db.Text
  descriptionAr String? @db.Text

  // Ownership: NULL = Platform-owned, otherwise Vendor-owned
  vendorId String?
  vendor   VendorProfile? @relation("VendorOwnedParts", fields: [vendorId], references: [id], onDelete: Cascade)

  // Added by (tracks who created the part, even if platform-owned)
  createdByUserId String
  createdByUser   User   @relation("VendorParts", fields: [createdByUserId], references: [id])

  categoryId String
  category   AutoPartCategory @relation(fields: [categoryId], references: [id])

  brand          String
  brandId        String? // علاقة بالماركة
  brandRef       VehicleBrand? @relation("AutoPartBrand", fields: [brandId], references: [id])
  vehicleModelId String? // علاقة بالموديل
  vehicleModel   VehicleModel? @relation(fields: [vehicleModelId], references: [id])
  year           Int? // سنة التصنيع
  partNumber     String?
  oemNumber      String?

  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  cost           Decimal? @db.Decimal(10, 2)

  stockQuantity     Int  @default(0)
  lowStockThreshold Int? @default(10)

  weight     Float?
  dimensions Json?

  specifications Json?

  // UI badges/tags (e.g., "Original", "Best Seller", "Warranty")
  badges Json?

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  // Admin approval for vendor parts
  isApproved Boolean   @default(true)
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images           AutoPartImage[]
  compatibility    AutoPartCompatibility[]
  orderItems       MarketplaceOrderItem[]
  cartItems        CartItem[]
  favorites        AutoPartFavorite[]
  autoPartServices AutoPartService[]
  autoPartVendors  AutoPartVendor[]
