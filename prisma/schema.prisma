  createdAt DateTime @default(now())

  booking Booking?

  @@index([requestId])
  @@index([mobileWorkshopId])
  @@index([status])
}

// ================================================================================================
// BOOKING CORE (Polymorphic - Supports All 4 Service Models)
// ================================================================================================

enum BookingStatus {
  // Universal States
  PENDING // Initial state
  CONFIRMED // Accepted by system/technician

  // Indrive Model States
  BROADCASTING // Looking for technicians
  OFFERS_RECEIVED // Technicians have bid
  TECHNICIAN_ASSIGNED // Customer selected a technician

  // Ekfik Model States
  PICKUP_SCHEDULED // Valet pickup scheduled
  IN_TRANSIT_PICKUP // Technician picking up vehicle
  INSPECTING // Vehicle being inspected
  QUOTE_PENDING // Waiting for customer approval
  QUOTE_APPROVED // Customer approved repairs
  QUOTE_REJECTED // Customer rejected - return vehicle

  // Execution States
  IN_PROGRESS // Work started
  PARTS_NEEDED // Technician requested parts
  PARTS_ORDERED // Parts requested from supplier
  PARTS_DELIVERED // Parts received

  // Completion States
  COMPLETED // Service finished
  READY_FOR_DELIVERY // Vehicle ready for return (Ekfik)
  IN_TRANSIT_DELIVERY // Returning vehicle
  DELIVERED // Vehicle returned to customer

  // Mobile / Towing tracking (technician en route, arrived, in service)
  TECHNICIAN_EN_ROUTE // Technician on the way to customer
  ON_THE_WAY // Alias for mobile car service flow
  ARRIVED // Technician arrived at location
  IN_SERVICE // Work in progress at location

  // Terminal States
  CANCELLED // Cancelled by customer/admin
  REJECTED // Rejected by technician
  NO_SHOW // Customer didn't show up
}

enum WorkType {
  WORK // عمل - أول مرة
  REWORK // إعادة عمل
}

model Booking {
  id            String @id @default(uuid())
  bookingNumber String @unique // AUTO-GEN: BKG-20260123-001

  // Relationships
  customerId String
  customer   User   @relation("CustomerBookings", fields: [customerId], references: [id])

  technicianId String?
  technician   User?   @relation("TechnicianBookings", fields: [technicianId], references: [id])

  vehicleId String?
  vehicle   UserVehicle? @relation(fields: [vehicleId], references: [id])

  addressId String?
  address   Address? @relation(fields: [addressId], references: [id])

  // Certified Workshop Fields
  workshopId     String?
  workshop       CertifiedWorkshop? @relation(fields: [workshopId], references: [id])
  deliveryMethod DeliveryMethod?
  flatbedFee     Decimal?           @default(0) @db.Decimal(10, 2)

  // Mobile Workshop (عند اختيار العميل لورشة من الطلب)
  mobileWorkshopId        String?
  mobileWorkshop          MobileWorkshop?        @relation(fields: [mobileWorkshopId], references: [id])
  mobileWorkshopRequestId String?                @unique
  mobileWorkshopRequest   MobileWorkshopRequest? @relation(fields: [mobileWorkshopRequestId], references: [id])
  mobileWorkshopOfferId   String?                @unique
  mobileWorkshopOffer     MobileWorkshopOffer?   @relation(fields: [mobileWorkshopOfferId], references: [id])

  /// Certified workshop: optional percent promo applied to this booking
  vendorWorkshopOfferId String?
  vendorWorkshopOffer   VendorWorkshopOffer? @relation("VendorWorkshopOfferPercentBooking", fields: [vendorWorkshopOfferId], references: [id], onDelete: SetNull)

  /// One-to-one: booking row created to pay for a prepaid bundle purchase
  workshopOfferBundlePurchase UserWorkshopOfferPurchase? @relation("WorkshopOfferPurchaseBooking")

  // Scheduling
  scheduledDate DateTime?
  scheduledTime String? // "09:00" - Store as string for flexibility
  completedAt   DateTime?

  // Location (for Emergency/Indrive model)
  pickupLat     Float?
  pickupLng     Float?
  pickupAddress String?

  destinationLat     Float?
  destinationLng     Float?
  destinationAddress String?

  // Pricing
  subtotal                  Decimal @default(0) @db.Decimal(10, 2)
  laborFee                  Decimal @default(0) @db.Decimal(10, 2)
  deliveryFee               Decimal @default(0) @db.Decimal(10, 2)
  partsTotal                Decimal @default(0) @db.Decimal(10, 2)
  discount                  Decimal @default(0) @db.Decimal(10, 2)
  tax                       Decimal @default(0) @db.Decimal(10, 2)
  totalPrice                Decimal @default(0) @db.Decimal(10, 2)
  // نسبة عمولة المنصة المسجلة وقت الحجز — تغيير النسبة لاحقاً يؤثر على الحجوزات القادمة فقط
  platformCommissionPercent Float?

  // Distance calculation (for delivery fee)
  distanceKm        Float?
  estimatedDuration Int? // minutes

  // Work type: عمل أولي أو إعادة عمل
  workType WorkType? @default(WORK)

  // Status & Metadata
  metadata      Json? // Additional data (vehicle condition, pricing, etc.)
  status        BookingStatus @default(PENDING)
  notes         String?       @db.Text
  internalNotes String?       @db.Text // Admin/Technician only

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  services                   BookingService[]
  bookingAutoParts           BookingAutoPart[] // Spare parts (e.g. Mobile Car Service)
  statusHistory              BookingStatusHistory[]
  jobBroadcast               JobBroadcast?
  inspectionReport           InspectionReport?
  supplyRequests             SupplyRequest[]
  invoice                    Invoice?
  rating                     Rating?
  workshopReview             WorkshopReview?
  notifications              Notification[]
  technicianLocations        TechnicianLocation[]   @relation("BookingTracking")
  chatRoom                   ChatRoom?
  /// Booking used to bill a package purchase (one-to-one from UserPackage)
  packagePurchaseUserPackage UserPackage?           @relation("UserPackagePurchaseBooking")

  // خدمة أكفيك — ربط حجوزات السحب/الورشة بالرحلة
  akfeekJourneyAsInsuranceTow  AkfeekJourney? @relation("AkfeekJourneyInsuranceTow")
  akfeekJourneyAsTowToWorkshop AkfeekJourney? @relation("AkfeekJourneyTowToWorkshop")
  akfeekJourneyAsWorkshop      AkfeekJourney? @relation("AkfeekJourneyWorkshop")
  akfeekJourneyAsReturnHome    AkfeekJourney? @relation("AkfeekJourneyReturnHome")

  @@index([customerId])
  @@index([technicianId])
  @@index([status])
  @@index([scheduledDate])
  @@index([createdAt])
  @@index([mobileWorkshopId])
}

model BookingService {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  // عند الحجز من خدمات الورش: ربط الخدمة المعروضة من الورشة (CertifiedWorkshopService)
  workshopServiceId String?
  workshopService   CertifiedWorkshopService? @relation(fields: [workshopServiceId], references: [id], onDelete: SetNull)

  // عند الحجز من الورشة المتنقلة: ربط خدمة الورشة المتنقلة
  mobileWorkshopServiceId String?
  mobileWorkshopService   MobileWorkshopService? @relation(fields: [mobileWorkshopServiceId], references: [id], onDelete: SetNull)

  quantity         Int     @default(1)
  unitPrice        Decimal @db.Decimal(10, 2)
  totalPrice       Decimal @db.Decimal(10, 2)
  estimatedMinutes Int? // وقت الخدمة بالدقائق (من Service أو CertifiedWorkshopService أو MobileWorkshopService)

  /// Slot consumed from UserWorkshopOfferPurchase (prepaid bundle)
  workshopOfferPurchaseId String?
  workshopOfferPurchase   UserWorkshopOfferPurchase? @relation(fields: [workshopOfferPurchaseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([serviceId])
  @@index([workshopServiceId])
  @@index([mobileWorkshopServiceId])
  @@index([workshopOfferPurchaseId])
}

// Spare parts on a booking (e.g. Mobile Car Service)
model BookingAutoPart {
  id         String         @id @default(uuid())
  bookingId  String
  booking    Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  autoPartId String
  autoPart   AutoPart       @relation(fields: [autoPartId], references: [id])
  vendorId   String? // Which vendor supplied (optional)
  vendor     VendorProfile? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([autoPartId])
  @@index([vendorId])
}

model BookingStatusHistory {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  fromStatus BookingStatus?
  toStatus   BookingStatus

  changedBy String? // userId
  reason    String? @db.Text
  metadata  Json? // Additional context

  timestamp DateTime @default(now())

  @@index([bookingId])
  @@index([timestamp])
}

// ================================================================================================
// INDRIVE/BROADCAST MODULE (Emergency Services)
// ================================================================================================

enum BroadcastStatus {
  BROADCASTING
  OFFERS_RECEIVED
  TECHNICIAN_SELECTED
  CANCELLED
  EXPIRED
}

model JobBroadcast {
  id        String  @id @default(uuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  // Location
  addressId       String?
  address         Address? @relation(fields: [addressId], references: [id])
  latitude        Float
  longitude       Float
  locationAddress String

  // Broadcast Settings
  radiusKm       Float    @default(10) // Search radius
  broadcastUntil DateTime // Expiry time

  // Problem Description
  description     String   @db.Text
  urgency         String? // LOW, MEDIUM, HIGH
  estimatedBudget Decimal? @db.Decimal(10, 2)

  status BroadcastStatus @default(BROADCASTING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  offers JobOffer[]

  @@index([customerId])
  @@index([status])
  @@index([latitude, longitude])
}

enum JobOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model JobOffer {
  id          String       @id @default(uuid())
  broadcastId String
  broadcast   JobBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  // من فني (User) أو من ونش (Vendor+Winch) — واحد منهما مطلوب
  technicianId String?
  technician   User?   @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  winchId      String?
  winch        Winch?  @relation(fields: [winchId], references: [id], onDelete: SetNull)

  // Offer Details — السعر يظهر للعميل (من pricePerKm للونش أو bidAmount للفني)
  bidAmount        Decimal @db.Decimal(10, 2)
  estimatedArrival Int // minutes
  message          String? @db.Text

  status JobOfferStatus @default(PENDING)

  // Location snapshot at time of offer (فني أو موقع الوينش)
  technicianLat Float?
  technicianLng Float?
  distanceKm    Float?

  isSelected Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([broadcastId])
  @@index([technicianId])
  @@index([winchId])
  @@index([isSelected])
  @@index([status])
}

// ================================================================================================
// INSPECTION & SUPPLY CHAIN MODULE (Ekfik Lifecycle)
// ================================================================================================

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  APPROVED
  REJECTED
  PENDING_CUSTOMER
}

model InspectionReport {
  id        String  @id @default(uuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  technicianId String
  technician   User   @relation(fields: [technicianId], references: [id])

  // Inspection Details
  mileage          Int
  inspectionDate   DateTime @default(now())
  overallCondition String? // GOOD, FAIR, POOR

  notes  String? @db.Text
  images Json? // Array of image URLs
  videos Json? // Array of video URLs

  // Quote
  estimatedCost     Decimal @db.Decimal(10, 2)
  estimatedDuration Int? // hours

  status InspectionStatus @default(PENDING)

  customerResponse String? // APPROVED, REJECTED
  customerComment  String?   @db.Text
  respondedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items InspectionItem[]

  @@index([bookingId])
  @@index([technicianId])
  @@index([status])
}

model InspectionItem {
  id       String           @id @default(uuid())
  reportId String
  report   InspectionReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  category String // "Engine", "Brakes", "Suspension"
  issue    String
  issueAr  String?
  severity String // LOW, MEDIUM, HIGH, CRITICAL

  recommendedAction String  @db.Text
  estimatedCost     Decimal @db.Decimal(10, 2)

  requiresPart Boolean @default(false)
  partName     String?
  partSku      String?

  priority Int @default(1) // Execution order

  createdAt DateTime @default(now())

  @@index([reportId])
}

// ================================================================================================
// SUPPLY REQUEST MODULE (Technician → Supplier)
// ================================================================================================

enum SupplyRequestStatus {
  PENDING
  ACCEPTED
  IN_PREPARATION
  READY_FOR_PICKUP
  IN_DELIVERY
  DELIVERED
  CANCELLED
  REJECTED
}

model SupplyRequest {
  id            String @id @default(uuid())
  requestNumber String @unique // AUTO-GEN: SR-20260123-001

  technicianId String
  technician   User   @relation("TechnicianSupplyRequests", fields: [technicianId], references: [id])

  supplierId String
  supplier   User   @relation("SupplierSupplyRequests", fields: [supplierId], references: [id])

  bookingId String? // Optional: Linked to specific booking
  booking   Booking? @relation(fields: [bookingId], references: [id])

  // Delivery Details
  deliveryAddress String
  deliveryLat     Float?
  deliveryLng     Float?

  // Pricing
  subtotal    Decimal @default(0) @db.Decimal(10, 2)
  deliveryFee Decimal @default(0) @db.Decimal(10, 2)
  markup      Decimal @default(0) @db.Decimal(10, 2) // Added to customer invoice
  totalCost   Decimal @default(0) @db.Decimal(10, 2)

  status SupplyRequestStatus @default(PENDING)
  notes  String?             @db.Text

  requestedAt DateTime  @default(now())
  acceptedAt  DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items       SupplyRequestItem[]
  transaction Transaction?

  @@index([technicianId])
  @@index([supplierId])
  @@index([bookingId])
  @@index([status])
}

model SupplyRequestItem {
  id        String        @id @default(uuid())
  requestId String
  request   SupplyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  partId String
  part   SupplierPart @relation(fields: [partId], references: [id])

  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([partId])
}

// ================================================================================================
// FINANCIAL DOMAIN
// ================================================================================================

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique // AUTO-GEN: INV-20260123-001

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  // Amounts
  subtotal    Decimal @db.Decimal(10, 2)
  tax         Decimal @default(0) @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)
  paidAmount  Decimal @default(0) @db.Decimal(10, 2)

  status InvoiceStatus @default(DRAFT)

  issuedAt DateTime  @default(now())
  dueDate  DateTime?
  paidAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lineItems InvoiceLineItem[]
  payments  Payment[]

  /// Set when invoice is for a prepaid workshop bundle purchase
  workshopOfferPurchase      UserWorkshopOfferPurchase?
  /// Set when invoice is for a packages purchase
  packagePurchaseUserPackage UserPackage?               @relation("UserPackagePurchaseInvoice")

  @@index([customerId])
  @@index([status])
  @@index([issuedAt])
}

model InvoiceLineItem {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description   String
  descriptionAr String?
  itemType      String // SERVICE, PRODUCT, LABOR, DELIVERY, PART

  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
  BANK_TRANSFER
  APPLE_PAY
  MADA
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id            String @id @default(uuid())
  paymentNumber String @unique // AUTO-GEN: PAY-20260123-001

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  amount Decimal       @db.Decimal(10, 2)
  method PaymentMethod
  status PaymentStatus @default(PENDING)

  // Payment Gateway Details
  gatewayReference String? @unique
  gatewayResponse  Json?

  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ربط بحركة المحفظة (عند الدفع من المحفظة) وبحركة النقاط
  walletTransaction Transaction?      @relation("PaymentWalletTransaction")
  pointsTransaction PointTransaction? @relation("PaymentPointsTransaction")

  @@index([invoiceId])
  @@index([customerId])
  @@index([status])
}

model Wallet {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  availableBalance Decimal @default(0) @db.Decimal(10, 2)
  pendingBalance   Decimal @default(0) @db.Decimal(10, 2) // Locked for pending transactions

  currency String @default("SAR")

  pointsBalance Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions      Transaction[]
  pointTransactions PointTransaction[]

  @@index([userId])
}

enum TransactionType {
  EARNING // Technician/Supplier income
  WITHDRAWAL // Cash out
  REFUND // Money returned
  COMMISSION // Platform fee deduction
  SUPPLY_PAYMENT // Payment for supply request
  ADJUSTMENT // Admin adjustment
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Transaction {
  id                String @id @default(uuid())
  transactionNumber String @unique // AUTO-GEN: TXN-20260123-001

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  balanceBefore Decimal         @db.Decimal(10, 2)
  balanceAfter  Decimal         @db.Decimal(10, 2)

  description String
  status      TransactionStatus @default(PENDING)

  // Related Entities
  supplyRequestId String?        @unique
  supplyRequest   SupplyRequest? @relation(fields: [supplyRequestId], references: [id])
  paymentId       String?        @unique
  payment         Payment?       @relation("PaymentWalletTransaction", fields: [paymentId], references: [id])

  metadata Json? // Additional context

  performedById String? @map("performedBy")
  performedBy   User?   @relation("TransactionPerformer", fields: [performedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([paymentId])
}

enum PointTransactionType {
  EARN
  REDEEM
  ADJUSTMENT
  REFUND
}

model PointTransaction {
  id String @id @default(uuid())

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          PointTransactionType
  amount        Int
  balanceBefore Int
  balanceAfter  Int

  description String?
  referenceId String?
  metadata    Json?
  paymentId   String?  @unique
  payment     Payment? @relation("PaymentPointsTransaction", fields: [paymentId], references: [id])

  performedById String? @map("performedBy")
  performedBy   User?   @relation("PointTransactionPerformer", fields: [performedById], references: [id])

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([userId])
  @@index([createdAt])
  @@index([paymentId])
}

// ================================================================================================
// RATING & REVIEW SYSTEM
// ================================================================================================

model Rating {
  id        String  @id @default(uuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  raterId String // Who gave the rating
  rater   User   @relation("RaterRatings", fields: [raterId], references: [id])

  rateeId String // Who received the rating
  ratee   User   @relation("RateeRatings", fields: [rateeId], references: [id])

  score  Int // 1-5 stars
  review String? @db.Text

  // Detailed Ratings (optional)
  punctuality     Int? // 1-5
  professionalism Int? // 1-5
  quality         Int? // 1-5
  communication   Int? // 1-5

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([raterId])
  @@index([rateeId])
}

// ================================================================================================
// NOTIFICATION SYSTEM
// ================================================================================================

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED

  BROADCAST_NEW
  OFFER_RECEIVED
  OFFER_ACCEPTED

  INSPECTION_SUBMITTED
  QUOTE_APPROVED
  QUOTE_REJECTED

  SUPPLY_REQUEST_NEW
  SUPPLY_REQUEST_ACCEPTED
  SUPPLY_DELIVERED

  PAYMENT_RECEIVED
  PAYMENT_FAILED

  WALLET
  POINTS

  STATUS_UPDATE
  MESSAGE
  SYSTEM
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  titleAr   String?
  message   String           @db.Text
  messageAr String?          @db.Text

  // Related Entity
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  metadata Json? // Additional data

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

// ================================================================================================
// CHAT (عميل + فيندور الورشة المتنقلة — غرفة لكل بوكينج)
// ================================================================================================

model ChatRoom {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([bookingId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
}

// ================================================================================================
// SYSTEM CONFIGURATION
// ================================================================================================

model SystemSettings {
  id    String @id @default(uuid())
  key   String @unique // e.g., "TOWING_SEARCH_RADIUS"
  value String // JSON or plain value
  type  String // "NUMBER", "JSON", "BOOLEAN", "STRING"

  description   String? // English description
  descriptionAr String? // Arabic description

  category   String  @default("GENERAL") // "TOWING", "GENERAL", "PRICING", "NOTIFICATION"
  isEditable Boolean @default(true) // Allow admin to edit

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// ================================================================================================
// REAL-TIME LOCATION TRACKING
// ================================================================================================

model TechnicianLocation {
  id           String @id @default(uuid())
  technicianId String
  technician   User   @relation("TechnicianLocations", fields: [technicianId], references: [id], onDelete: Cascade)

  // Current GPS location
  latitude  Float
  longitude Float
  heading   Float? // Direction in degrees (0-360)
  speed     Float? // Speed in km/h
  accuracy  Float? // GPS accuracy in meters

  // Context - which booking is this technician working on
  bookingId String?
  booking   Booking? @relation("BookingTracking", fields: [bookingId], references: [id], onDelete: SetNull)

  // Status
  status String @default("ONLINE") // OFFLINE, ONLINE, ON_JOB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([technicianId])
  @@index([bookingId])
  @@index([createdAt])
}

// ================================================================================================
// MARKETPLACE ORDERS
// ================================================================================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ================================================================================================
// CART (Customer shopping cart before checkout)
// ================================================================================================

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]

  @@index([userId])
}

model CartItem {
  id         String   @id @default(uuid())
  cartId     String
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  autoPartId String
  autoPart   AutoPart @relation(fields: [autoPartId], references: [id], onDelete: Cascade)
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2) // Snapshot at add time for display
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([cartId, autoPartId])
  @@index([cartId])
  @@index([autoPartId])
}

// Customer wishlist for marketplace auto parts (not the shopping cart)
model AutoPartFavorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoPartId String
  autoPart   AutoPart @relation(fields: [autoPartId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, autoPartId])
  @@index([userId])
  @@index([autoPartId])
}

// ================================================================================================
// MARKETPLACE ORDERS (after checkout from cart)
// ================================================================================================

model MarketplaceOrder {
  id          String @id @default(uuid())
  orderNumber String @unique // ORD-202X-XXXX

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  // Financials
  subtotal     Decimal @db.Decimal(10, 2)
  tax          Decimal @db.Decimal(10, 2)
  shippingCost Decimal @db.Decimal(10, 2)
  discount     Decimal @default(0) @db.Decimal(10, 2)
  totalAmount  Decimal @db.Decimal(10, 2)

  status        OrderStatus @default(PENDING)
  paymentStatus String      @default("PENDING") // PENDING, PAID, FAILED
  paymentMethod String? // CARD, CASH, WALLET

  // Shipping details snapshot
  shippingAddress String? @db.Text
  shippingCity    String?
  shippingCountry String  @default("SA")
  recipientName   String?
  recipientPhone  String?

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     MarketplaceOrderItem[]
  feedbacks Feedback[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model MarketplaceOrderItem {
  id String @id @default(uuid())

  orderId String
  order   MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  autoPartId String
  autoPart   AutoPart @relation(fields: [autoPartId], references: [id])

  vendorId String?
  vendor   VendorProfile? @relation(fields: [vendorId], references: [id])

  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  // Per-item status allows partial fulfillment in multi-vendor orders
  status OrderStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([vendorId])
  @@index([status])
}

// ================================================================================================
// SYSTEM ACTIVITY LOG
// ================================================================================================

model ActivityLog {
  id     String  @id @default(uuid())
  userId String? // Optional: System actions might not have a user
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String // e.g., "USER_LOGIN", "BOOKING_CREATED"
  entity   String // e.g., "Booking", "User", "Invoice"
  entityId String? // ID of the affected entity

  details   Json? // Flexible payload for details (diff, ip, user agent)
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ================================================================================================
// FEEDBACK & COMPLAINTS MODULE
// ================================================================================================

enum FeedbackType {
  COMPLAINT
  SUGGESTION
}

enum FeedbackCategory {
  DELIVERY
  PAYMENT
  PRODUCT
  UI_UX
  OTHER
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
  CLOSED
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FeedbackSenderType {
  USER
  ADMIN
}

model Feedback {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation("UserFeedbacks", fields: [userId], references: [id], onDelete: SetNull)

  orderId String?
  order   MarketplaceOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  type        FeedbackType
  category    FeedbackCategory
  subject     String
  message     String           @db.Text
  status      FeedbackStatus   @default(OPEN)
  priority    FeedbackPriority @default(MEDIUM)
  isAnonymous Boolean          @default(false)

  resolvedAt DateTime?
  handledBy  String?
  handler    User?     @relation("HandledFeedbacks", fields: [handledBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  deletedAt DateTime?

  replies   FeedbackReply[]
  auditLogs FeedbackAuditLog[]

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
  @@index([deletedAt])
}

model FeedbackReply {
  id         String   @id @default(uuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  senderType FeedbackSenderType
  senderId   String
  sender     User               @relation(fields: [senderId], references: [id])

  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([feedbackId])
  @@index([senderId])
}

model FeedbackAuditLog {
  id         String   @id @default(uuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  oldStatus FeedbackStatus?
  newStatus FeedbackStatus
  changedBy String?
  changer   User?           @relation(fields: [changedBy], references: [id])

  notes     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([feedbackId])
  @@index([changedBy])
}

// ================================================================================================
// VENDOR ONBOARDING MODULE
// ================================================================================================

enum VendorRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// الفيندور يبيع للمستخدمين عبر التطبيق (منصة فقط)
enum OperatingModel {
  MARKETPLACE
}

model Vendor {
  id           String  @id @default(uuid())
  userId       String? @unique
  user         User?   @relation("VendorApplication", fields: [userId], references: [id])
  supplierId   String? @unique
  legalName    String
  tradeName    String?
  supplierType String

  // Requested vendor type (used on approval to create VendorProfile)
  vendorType VendorType @default(AUTO_PARTS)

  // Address & Registration
  country           String
  city              String
  addressLine1      String
  nationalAddress   String
  postalCode        String
  commercialRegNo   String  @unique
  vatRegistered     Boolean @default(false)
  vatNumber         String?
  eInvoicingCapable Boolean @default(false)

  // Contacts
  website             String?
  companyEmail        String  @unique
  companyPhone        String
  contactPersonName   String
  contactPersonTitle  String
  contactPersonMobile String

  // Scope Alignment
  mainService       String
  subService        String?
  servicesOffered   String         @db.Text
  coverageRegion    String
  operatingModel    OperatingModel @default(MARKETPLACE)
  support24_7       Boolean        @default(false)
  emergencyResponse Boolean        @default(false)

  // Capacity
  yearsOfExperience   Int?
  employeesBand       String?
  monthlyCapacityBand String?
  fleetCount          Int?    @default(0)

  // Commercials
  paymentTerms      String?
  currency          String  @default("SAR")
  priceListProvided Boolean @default(false)
  discountPercent   Float?
  payoutMethod      String
  bankName          String?
  iban              String?

  // Workflow
  status    VendorRegistrationStatus @default(PENDING)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  // Relations
  coverageCities VendorCity[]
  users          User[]

  @@index([status])
  @@index([city])
}

model VendorCity {
  id        String   @id @default(uuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  cityName  String
  createdAt DateTime @default(now())

  @@index([vendorId])
}

// ================================================================================================
// TECHNICAL SUPPORT MODULE
// ================================================================================================

enum TechnicalSupportStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TechnicalSupportRequest {
  id     String @id @default(uuid())
  number String @unique

  customerId String
  customer   User   @relation("CustomerSupportRequests", fields: [customerId], references: [id])

  technicianId String?
  technician   User?   @relation("TechnicianSupportRequests", fields: [technicianId], references: [id])

  assignedById String?
  assignedBy   User?   @relation("AssignedSupportRequests", fields: [assignedById], references: [id])

  assignedAt DateTime?

  vehicleSerialNumber String
  plateNumber         String
  hasInsurance        Boolean @default(false)
  insuranceCompany    String?
  deliveryAddress     String

  repairAuthUrl    String?
  najmDocUrl       String?
  trafficReportUrl String?

  accidentDamages String @db.Text
  carImageUrls    Json?

  status TechnicalSupportStatus @default(PENDING)
  notes  String?                @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([technicianId])
  @@index([status])
}

// ================================================================================================
// AKFEEK JOURNEY (خدمة أكفيك — رحلة موجّهة)
// ================================================================================================

enum AkfeekJourneyStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum AkfeekJourneyStep {
  INSURANCE_TOW
  INSURANCE_DOCS
  TOW_TO_WORKSHOP
  WORKSHOP_BOOKING
  POST_REPAIR_TOW_HOME
}

model AkfeekJourney {
  id         String       @id @default(uuid())
  customerId String
  customer   User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId  String?
  vehicle    UserVehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  status      AkfeekJourneyStatus @default(ACTIVE)
  currentStep AkfeekJourneyStep   @default(INSURANCE_TOW)

  insuranceTowBookingId String?  @unique
  insuranceTowBooking   Booking? @relation("AkfeekJourneyInsuranceTow", fields: [insuranceTowBookingId], references: [id], onDelete: SetNull)

  towToWorkshopBookingId String?  @unique
  towToWorkshopBooking   Booking? @relation("AkfeekJourneyTowToWorkshop", fields: [towToWorkshopBookingId], references: [id], onDelete: SetNull)

  workshopBookingId String?  @unique
  workshopBooking   Booking? @relation("AkfeekJourneyWorkshop", fields: [workshopBookingId], references: [id], onDelete: SetNull)

  returnHomeBookingId String?  @unique
  returnHomeBooking   Booking? @relation("AkfeekJourneyReturnHome", fields: [returnHomeBookingId], references: [id], onDelete: SetNull)

  insuranceTowSkipped    Boolean @default(false)
  insuranceDocsSkipped   Boolean @default(false)
  insuranceDocsCompleted Boolean @default(false)
  towToWorkshopSkipped   Boolean @default(false)
  workshopSkipped        Boolean @default(false)
  returnHomeDeclined     Boolean @default(false)

  documents AkfeekJourneyDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, status])
}

model AkfeekJourneyDocument {
  id        String        @id @default(uuid())
  journeyId String
  journey   AkfeekJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  label        String // repair_auth, najm, traffic_report, other
  fileUrl      String
  mimeType     String?
  originalName String?

  createdAt DateTime @default(now())

  @@index([journeyId])
}

// ================================================================================================
// BANNERS (Top / Bottom)
// ================================================================================================

enum BannerPosition {
  TOP
  BOTTOM
  AUTO_PARTS
  CAR_WASH
}

model Banner {
  id        String         @id @default(uuid())
  position  BannerPosition
  title     String?
  titleAr   String?
  isActive  Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  images BannerImage[]

  @@index([position, isActive, sortOrder])
}

model BannerImage {
  id        String   @id @default(uuid())
  bannerId  String
  banner    Banner   @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  imageUrl  String
  linkUrl   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([bannerId, sortOrder])
}

// ================================================================================================
// ABOUT US (من نحن) — mobile screen + admin dashboard CMS
// ================================================================================================

model AboutUsPage {
  id                   String   @id @default(uuid())
  brandNameEn          String   @default("Akfeek")
  brandNameAr          String   @default("أكفيك")
  /// Main logo shown on About Us (relative /uploads/... or absolute URL)
  logoUrl              String?
  introHeadingAr       String   @default("")
  introHeadingEn       String?
  /// MySQL TEXT cannot have a default — seed / getOrCreate sets this
  introBodyAr          String   @db.Text
  introBodyEn          String?  @db.Text
  valuesSectionTitleAr String   @default("القيم الأساسية")
  valuesSectionTitleEn String?  @default("Core values")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  coreValues AboutUsCoreValue[]

  @@map("about_us_pages")
}

model AboutUsCoreValue {
  id            String      @id @default(uuid())
  pageId        String
  page          AboutUsPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  sortOrder     Int         @default(0)
  titleAr       String
  titleEn       String?
  descriptionAr String      @db.Text
  descriptionEn String?     @db.Text
  /// Preset for app icons: check_badge | sparkles | shield | star
  iconKey       String      @default("sparkles")
  /// Optional uploaded icon (relative /uploads/... or absolute)
  iconUrl       String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([pageId, sortOrder])
  @@map("about_us_core_values")
}

// ================================================================================================
// PACKAGES SYSTEM - Subscription/Package Management
// ================================================================================================

enum PackageDealType {
  STANDARD
  PERCENT_SUBSCRIPTION
}

enum UserPackageStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

model Package {
  id              String          @id @default(uuid())
  name            String
  nameAr          String?
  description     String?         @db.Text
  descriptionAr   String?         @db.Text
  price           Decimal         @db.Decimal(10, 2)
  usageCount      Int? // null = unlimited
  validityDays    Int // days until expiry
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  imageUrl        String?
  dealType        PackageDealType @default(STANDARD)
  /// Required when dealType = PERCENT_SUBSCRIPTION (1–100)
  discountPercent Int?
  /// Optional reference total before discount (for “save X%” UI)
  listPriceTotal  Decimal?        @db.Decimal(10, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  services     PackageService[]
  userPackages UserPackage[]

  @@index([isActive])
  @@index([sortOrder])
  @@index([dealType, isActive])
}

model PackageService {
  id        String  @id @default(uuid())
  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([packageId, serviceId])
  @@index([packageId])
  @@index([serviceId])
}

model UserPackage {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId   String
  package     Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  purchasedAt DateTime @default(now())
  expiresAt   DateTime

  /// Purchase lifecycle: package becomes ACTIVE only after paying its invoice
  status   UserPackageStatus @default(PENDING_PAYMENT)
  isActive Boolean           @default(false)

  /// Booking + invoice created for paying this package
  purchaseBookingId String?  @unique
  purchaseBooking   Booking? @relation("UserPackagePurchaseBooking", fields: [purchaseBookingId], references: [id], onDelete: SetNull)
  invoiceId         String?  @unique
  invoice           Invoice? @relation("UserPackagePurchaseInvoice", fields: [invoiceId], references: [id], onDelete: SetNull)

  usages UserPackageServiceUsage[]

  @@index([userId])
  @@index([expiresAt])
  @@index([isActive])
  @@index([status])
}

model UserPackageServiceUsage {
  id            String      @id @default(uuid())
  userPackageId String
  userPackage   UserPackage @relation(fields: [userPackageId], references: [id], onDelete: Cascade)
  serviceId     String
  usedCount     Int         @default(0)
  lastUsedAt    DateTime?

  @@unique([userPackageId, serviceId])
  @@index([userPackageId])
}

model UserVehicleDocument {
  id        String      @id @default(uuid())
  vehicleId String
  vehicle   UserVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  type       String // drivingLicense | registrationForm | insurance | inspectionReport
  status     String // expiring | expired | renewalRequired | renewed
  expiryDate DateTime?
  fileUrl    String?

  @@unique([vehicleId, type])
  @@index([vehicleId])
  @@index([type])
}
