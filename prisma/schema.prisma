  vendorId String?        @unique
  vendor   VendorProfile? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  // Relations
  bookings               Booking[]
  reviews                WorkshopReview[]
  workshopServices       CertifiedWorkshopService[]
  vendorWorkshopOffers   VendorWorkshopOffer[]
  workshopOfferPurchases UserWorkshopOfferPurchase[]

  @@index([isActive, isVerified])
  @@index([city])
  @@index([averageRating])
  @@index([vendorId])
}

model CertifiedWorkshopService {
  id         String            @id @default(uuid())
  workshopId String
  workshop   CertifiedWorkshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  serviceType       String // ENGINE_REPAIR, BRAKE, OIL_CHANGE, TIRE, AC, ELECTRICAL, SUSPENSION, BODY_REPAIR, PAINTING, DIAGNOSIS, BATTERY, TRANSMISSION, GENERAL, CUSTOM
  name              String
  nameAr            String?
  description       String? @db.Text
  price             Float
  currency          String  @default("SAR")
  estimatedDuration Int? // بالدقائق
