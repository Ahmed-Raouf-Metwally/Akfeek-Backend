  nameAr      String?
  description String? @db.Text

  // نوع الورشة (من كاتالوج الأدمن)
  workshopTypeId String?
  workshopType   MobileWorkshopType? @relation(fields: [workshopTypeId], references: [id], onDelete: SetNull)

