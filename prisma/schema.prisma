// ================================================================================================
// CERTIFIED WORKSHOPS
// ================================================================================================

model CertifiedWorkshop {
  id            String  @id @default(uuid())
  name          String
  nameAr        String?
  description   String? @db.Text
  descriptionAr String? @db.Text

  // Location
  address   String
  addressAr String?
  city      String
  cityAr    String?
  latitude  Float
  longitude Float

  // Contact
  phone String
  email String?

  // Working Hours (JSON format: {"sunday": {"open": "08:00", "close": "18:00"}, ...})
  workingHours Json?

  // Services Offered (JSON array of service types)
  services String @db.Text

  // Ratings & Stats
  averageRating Float? @default(0)
  totalReviews  Int    @default(0)
  totalBookings Int    @default(0)

  // Capacity Management
  maxDailyCapacity Int? // Maximum bookings per day (optional)

  // Media
  logo   String?
  images Json? // Array of image URLs

  // Warranty
  warrantyMonths Int? // Warranty period in months (e.g., 6)

  // Status
  isActive   Boolean   @default(true)
  isVerified Boolean   @default(false)
  verifiedAt DateTime?

