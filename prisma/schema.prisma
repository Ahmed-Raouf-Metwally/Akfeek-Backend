  requestId               String
  request                 MobileWorkshopRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  mobileWorkshopId        String
  mobileWorkshop          MobileWorkshop         @relation(fields: [mobileWorkshopId], references: [id], onDelete: Cascade)
  mobileWorkshopServiceId String?
  mobileWorkshopService   MobileWorkshopService? @relation(fields: [mobileWorkshopServiceId], references: [id], onDelete: SetNull)

