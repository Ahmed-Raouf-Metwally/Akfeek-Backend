// ================================================================================================
// VENDOR WORKSHOP OFFERS (Certified workshop — percent on service(s) or prepaid bundle)
// ================================================================================================

enum VendorWorkshopOfferType {
  PERCENT_DISCOUNT
  PREPAID_BUNDLE
}

enum WorkshopOfferDiscountScope {
  ALL_SERVICES
  ONE_SERVICE
}

enum UserWorkshopOfferPurchaseStatus {
  PENDING_PAYMENT
  ACTIVE
  DEPLETED
  EXPIRED
  CANCELLED
}

model VendorWorkshopOffer {
  id         String            @id @default(uuid())
  workshopId String
  workshop   CertifiedWorkshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  offerType VendorWorkshopOfferType

  title         String
  titleAr       String?
  description   String? @db.Text
  descriptionAr String? @db.Text

  validFrom  DateTime @default(now())
  validUntil DateTime
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)

  /// Empty or null = all vehicle models; else array of VehicleModel ids (JSON string[])
  vehicleModelIds Json?

  discountScope   WorkshopOfferDiscountScope?
  /// 1–100 when offerType = PERCENT_DISCOUNT
  discountPercent Int?

  /// Target workshop line item (required for PREPAID_BUNDLE; for PERCENT + ONE_SERVICE)
  certifiedWorkshopServiceId String?
  certifiedWorkshopService   CertifiedWorkshopService? @relation(fields: [certifiedWorkshopServiceId], references: [id], onDelete: SetNull)

  paidSlots    Int?
  bonusSlots   Int?
  bundlePrice  Decimal? @db.Decimal(10, 2)
  validityDays Int?

  purchases UserWorkshopOfferPurchase[]

  percentAppliedBookings Booking[] @relation("VendorWorkshopOfferPercentBooking")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workshopId, isActive])
  @@index([workshopId, offerType])
}

model UserWorkshopOfferPurchase {
  id         String              @id @default(uuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  offerId    String
  offer      VendorWorkshopOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  workshopId String
  workshop   CertifiedWorkshop   @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  totalSlots Int
  usedSlots  Int      @default(0)
  expiresAt  DateTime

  status UserWorkshopOfferPurchaseStatus @default(PENDING_PAYMENT)

  /// Booking created to bill the bundle (one-time payment)
  purchaseBookingId String?  @unique
  purchaseBooking   Booking? @relation("WorkshopOfferPurchaseBooking", fields: [purchaseBookingId], references: [id], onDelete: SetNull)

  invoiceId String?  @unique
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  consumedInBookingServices BookingService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([offerId])
  @@index([workshopId])
}

model WorkshopReview {
  id String @id @default(uuid())

  // Relations
  workshopId String
  workshop   CertifiedWorkshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  // Review Content
  rating    Int     @db.SmallInt // 1-5 stars
  comment   String? @db.Text
  commentAr String? @db.Text

  // Response from workshop (optional)
  response    String?   @db.Text
  responseAr  String?   @db.Text
  respondedAt DateTime?

  // Status
  isApproved Boolean @default(true) // Admin can hide inappropriate reviews
  isVerified Boolean @default(false) // Verified purchase (has booking)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workshopId, isApproved])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

