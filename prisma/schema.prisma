  latitude      Float?
  longitude     Float?
  serviceRadius Float? // نطاق الخدمة بالكيلومتر

  // Pricing
  basePrice  Float? // سعر الزيارة الأساسي
  pricePerKm Float? // سعر كل كيلومتر
  hourlyRate Float? // سعر الساعة
  minPrice   Float?
  currency   String? @default("SAR")

  // Media
  imageUrl        String? // صورة الفني / الشعار
  vehicleImageUrl String? // صورة المركبة

